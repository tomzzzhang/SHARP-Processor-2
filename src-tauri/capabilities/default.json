{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:read-all",
    "fs:allow-write-file",
    "fs:write-all",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$TEMP/**" },
        { "path": "$HOME/**" },
        { "path": "**" }
      ]
    },
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "shell:default",
    "shell:allow-open"
  ]
}
